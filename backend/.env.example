# =============================================================================
# AI Startup Analyst API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values before running the app.
# Fields marked [REQUIRED] must be set — the app will refuse to start without them.
# Fields marked [OPTIONAL] have sensible defaults and can be left as-is locally.
# =============================================================================

# -----------------------------------------------------------------------------
# Application Identity                                          [OPTIONAL]
# -----------------------------------------------------------------------------
APP_NAME="AI Startup Analyst API"
APP_VERSION="1.0.0"

# Runtime environment: development | staging | production | test
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Server                                                        [OPTIONAL]
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=["http://localhost:3000"]

# -----------------------------------------------------------------------------
# Database                                                      [REQUIRED]
# -----------------------------------------------------------------------------
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/ai_analyst

# -----------------------------------------------------------------------------
# Security                                                      [REQUIRED]
# -----------------------------------------------------------------------------
# Generate a strong key: openssl rand -hex 32
SECRET_KEY=replace-with-a-real-64-char-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# AI / LLM                                                      [REQUIRED]
# -----------------------------------------------------------------------------
OPENAI_API_KEY=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
# -----------------------------------------------------------------------------
# Vector Database                                               [REQUIRED]
# -----------------------------------------------------------------------------
# Choose: faiss (local, no extra config needed) | pinecone (cloud)
VECTOR_DB_TYPE=faiss

# -- Pinecone — only required when VECTOR_DB_TYPE=pinecone -------------------
# PINECONE_API_KEY=your-pinecone-api-key
# PINECONE_ENVIRONMENT=us-east-1-aws

# -----------------------------------------------------------------------------
# External Microservices                                        [OPTIONAL]
# -----------------------------------------------------------------------------
AI_ENGINE_URL=http://localhost:8001
